# NASA ADS API token — get yours at https://ui.adsabs.harvard.edu/user/settings/token
ADS_API_TOKEN=your_ads_api_token_here

# LLM provider: "claude" (default) or "local"
LLM_PROVIDER=claude

# Anthropic API key (required when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# Local LLM settings (required when LLM_PROVIDER=local)
# Base URL for OpenAI-compatible API (Ollama, LM Studio, vLLM, etc.)
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.2
LOCAL_LLM_API_KEY=ollama   # many local servers ignore this

# Output directory for research artifacts
OUTPUT_DIR=./outputs

# Max papers to retrieve per search (default: 20)
ADS_MAX_RESULTS=20

# Web search provider: "none" (default) or "tavily"
WEB_SEARCH_PROVIDER=none
TAVILY_API_KEY=
